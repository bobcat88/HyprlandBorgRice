[
    {
        "name": "App Launcher",
        "alias": "app",
        "type": "app_launcher",
        "args": {
            "use_keywords": true
        },
        "priority": 3,
        "home": "Home"
    },
    {
        "name": "Calculator",
        "type": "calculation",
        "args": {
            "capabilities": [
                "calc.math",
                "calc.units"
            ]
        },
        "priority": 1,
        "on_return": "copy"
    },
    {
        "name": "Clipboard",
        "type": "clipboard-execution",
        "args": {
            "capabilities": [
                "url",
                "colors.hex",
                "colors.rgb",
                "colors.hsl",
                "calc.math",
                "calc.lengths",
                "calc.temperatures"
            ]
        },
        "priority": 1,
        "home": "Home"
    },
    {
        "name": "Music",
        "type": "audio_sink",
        "args": {},
        "async": true,
        "priority": 1,
        "home": "OnlyHome",
        "spawn_focus": false,
        "binds": [
            {
                "bind": "Return",
                "callback": "playpause",
                "exit": false
            },
            {
                "bind": "ctrl+l",
                "callback": "next",
                "exit": false
            },
            {
                "bind": "ctrl+h",
                "callback": "previous",
                "exit": false
            }
        ],
        "actions": [
            {
                "name": "Skip",
                "icon": "media-seek-forward",
                "method": "inner.next",
                "exit": false
            },
            {
                "name": "Previous",
                "icon": "media-seek-backward",
                "method": "inner.previous",
                "exit": false
            }
        ]
    },
    {
        "name": "Web Search",
        "display_name": "Google",
        "tag_start": "{keyword}",
        "alias": "gg",
        "type": "web_launcher",
        "args": {
            "search_engine": "google",
            "icon": "google"
        },
        "priority": 100
    },
    {
        "name": "Web Search",
        "display_name": "DuckDuckGo",
        "tag_start": "{keyword}",
        "alias": "ddg",
        "type": "web_launcher",
        "args": {
            "search_engine": "duckduckgo",
            "icon": "duckduckgo"
        },
        "priority": 100
    },
    {
        "name": "Emoji Picker",
        "alias": "emoji",
        "type": "emoji_picker",
        "args": {
            "default_skin_tone": "Simpsons"
        },
        "priority": 0
    },
    {
        "name": "Kill Process",
        "alias": "kill",
        "type": "process",
        "args": {},
        "priority": 0
    },
    {
        "name": "System",
        "alias": "sys",
        "type": "categories",
        "args": {
            "Kill Processes": {
                "icon": "sherlock-process",
                "icon_class": "reactive",
                "exec": "kill",
                "search_string": "kill;terminate;process"
            },
            "Power Menu": {
                "icon": "system-shutdown-symbolic",
                "icon_class": "reactive",
                "exec": "pm",
                "search_string": "power;shutdown;reboot;logout"
            },
            "Themes": {
                "icon": "preferences-desktop-theme-symbolic",
                "icon_class": "reactive",
                "exec": "themes",
                "search_string": "themes;appearance"
            }
        },
        "priority": 2,
        "home": "Home"
    },
    {
        "name": "Power Menu",
        "alias": "pm",
        "type": "command",
        "args": {
            "commands": {
                "Lock": {
                    "icon": "system-lock-screen-symbolic",
                    "exec": "swaylock",
                    "search_string": "lock"
                },
                "Logout": {
                    "icon": "system-log-out-symbolic",
                    "exec": "hyprctl dispatch exit",
                    "search_string": "logout;exit;quit"
                },
                "Reboot": {
                    "icon": "system-reboot-symbolic",
                    "exec": "systemctl reboot",
                    "search_string": "reboot;restart"
                },
                "Shutdown": {
                    "icon": "system-shutdown-symbolic",
                    "exec": "systemctl poweroff",
                    "search_string": "shutdown;poweroff;halt"
                },
                "Suspend": {
                    "icon": "media-playback-pause-symbolic",
                    "exec": "systemctl suspend",
                    "search_string": "suspend;sleep"
                }
            }
        },
        "priority": 0
    },
    {
        "name": "Theme Picker",
        "alias": "themes",
        "type": "theme_picker",
        "args": {
            "location": "~/.config/sherlock/themes/"
        },
        "priority": 0
    },
    {
        "name": "Debug",
        "alias": "debug",
        "type": "debug",
        "args": {
            "commands": {
                "Clear Cache": {
                    "icon": "sherlock-process",
                    "exec": "clear_cache",
                    "search_string": "clear;cache"
                },
                "Reset App Counts": {
                    "icon": "sherlock-process",
                    "exec": "reset_counts",
                    "search_string": "reset;counts"
                }
            }
        },
        "priority": 0
    }
]
